From 4c85968de2f54156e5e737e63bd0b714abb80700 Mon Sep 17 00:00:00 2001
From: Shubham Vishwakarma <shubhamvis98@fossfrog.in>
Date: Mon, 16 Jun 2025 05:54:19 +0000
Subject: [PATCH] winbound clear block protection bits

---
 core.c    |  3 ++-
 winbond.c | 22 ++++++++++++++++++++++
 2 files changed, 24 insertions(+), 1 deletion(-)

diff --git a/drivers/mtd/nand/spi/core.c b/drivers/mtd/nand/spi/core.c
index f97cf68..725fa10 100644
--- a/drivers/mtd/nand/spi/core.c
+++ b/drivers/mtd/nand/spi/core.c
@@ -20,7 +20,8 @@
 #include <linux/spi/spi.h>
 #include <linux/spi/spi-mem.h>
 
-static int spinand_read_reg_op(struct spinand_device *spinand, u8 reg, u8 *val)
+int spinand_read_reg_op(struct spinand_device *spinand, u8 reg, u8 *val);
+int spinand_read_reg_op(struct spinand_device *spinand, u8 reg, u8 *val)
 {
 	struct spi_mem_op op = SPINAND_GET_FEATURE_OP(reg,
 						      spinand->scratchbuf);
diff --git a/drivers/mtd/nand/spi/winbond.c b/drivers/mtd/nand/spi/winbond.c
index a33ad04..c055819 100644
--- a/drivers/mtd/nand/spi/winbond.c
+++ b/drivers/mtd/nand/spi/winbond.c
@@ -17,6 +17,9 @@
 
 #define W25N04KV_STATUS_ECC_5_8_BITFLIPS	(3 << 4)
 
+#define WINBOND_CMD_WRST  0x01  /* Write Status Register */
+#define WINBOND_CMD_RDST  0x0F  /* Read Status Register */
+
 static SPINAND_OP_VARIANTS(read_cache_variants,
 		SPINAND_PAGE_READ_FROM_CACHE_QUADIO_OP(0, 2, NULL, 0),
 		SPINAND_PAGE_READ_FROM_CACHE_X4_OP(0, 1, NULL, 0),
@@ -254,6 +257,23 @@ static const struct spinand_info winbond_spinand_table[] = {
 		     SPINAND_ECCINFO(&w25n02kv_ooblayout, w25n02kv_ecc_get_status)),
 };
 
+extern int spinand_read_reg_op(struct spinand_device *spinand, u8 reg, u8 *val);
+static int winbond_disable_block_protection(struct spinand_device *spinand)
+{
+	u8 status;
+	int ret;
+
+	ret = spinand_read_reg_op(spinand, WINBOND_CMD_RDST, &status);
+	if (ret)
+		return ret;
+
+	/* Clear block protection bits BP[2:0] (bits 4:2) */
+	status &= ~GENMASK(4, 2);
+
+	ret = spinand_write_reg_op(spinand, WINBOND_CMD_WRST, status);
+	return ret;
+}
+
 static int winbond_spinand_init(struct spinand_device *spinand)
 {
 	struct nand_device *nand = spinand_to_nand(spinand);
@@ -269,6 +289,8 @@ static int winbond_spinand_init(struct spinand_device *spinand)
 				WINBOND_CFG_BUF_READ);
 	}
 
+	winbond_disable_block_protection(spinand);
+
 	return 0;
 }
 
-- 
